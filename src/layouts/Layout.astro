---
import '../styles/global.css';
const { title = 'GameHub', lang = 'en' } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script is:inline>
      (function() {
        function applyScale() {
          var app = document.querySelector('.app');
          if (!app) return;
          var scale = Math.min(1, window.innerWidth / 1440);
          if (scale < 1) {
            app.style.transform = 'scale(' + scale + ')';
            app.style.transformOrigin = 'top left';
            app.style.marginBottom = -(app.scrollHeight * (1 - scale)) + 'px';
          } else {
            app.style.transform = '';
            app.style.transformOrigin = '';
            app.style.marginBottom = '';
          }
        }
        applyScale();
        window.addEventListener('resize', applyScale);
      })();
    </script>
    <script>
      function initReveal() {
        const textSelectors = [
          '.hero-title', '.hero-headline',
          '.hero-subtitle', '.hero-caption',
          '.showcase-title', '.showcase-subtitle',
          '.steam-management-title', '.steam-management-subtitle',
          '.steam-data-text',
          '.compat-title', '.compat-desc', '.compat-card-title', '.compat-card-desc',
          '.survey-title', '.survey-desc',
          '.feature-preview-title', '.feature-preview-desc',
          '.feature-card-title', '.feature-card-desc',
          '.faq-title', '.faq-subtitle', '.faq-bottom-logo-text',
        ];
        const cardSelectors = [
          '.showcase-box-anim',
        ];
        const allSelectors = [...textSelectors, ...cardSelectors];
        const els = document.querySelectorAll(allSelectors.join(','));
        if (els.length === 0) {
          requestAnimationFrame(initReveal);
          return;
        }
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('is-revealed');
            } else {
              e.target.classList.remove('is-revealed');
            }
          });
        }, { threshold: 0.1 });
        els.forEach((el) => observer.observe(el));
      }
      initReveal();
    </script>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
